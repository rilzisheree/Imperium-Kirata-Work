modules = ["lua-5.2"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Rojo Serve"

[[workflows.workflow]]
name = "Rojo Serve"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "./rojo serve default.project.json --address 0.0.0.0 --port 8000"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 8000
externalPort = 8000
