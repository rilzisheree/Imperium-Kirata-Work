modules = ["python-3.11"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Rojo Serve"

[[workflows.workflow]]
name = "Rojo Serve"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "./rojo serve default.project.json --port 8080"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"
